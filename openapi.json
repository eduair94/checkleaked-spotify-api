overview","description":"Comprehensive artist data — profile, visuals, top tracks, stats, related artists, discography.","tags":["Partner"],"parameters":[{"name":"id","in":"query","required":true,"schema":{"type":"string"}},{"name":"locale","in":"query","schema":{"type":"string","default":"en"}},{"name":"includePrerelease","in":"query","schema":{"type":"boolean","default":false}}],"responses":{"200":{"description":"Artist overview"}}}},"/partner/artist-discography":{"get":{"summary":"Partner artist discography","description":"Full artist discography — albums, singles, EPs, compilations with pagination.","tags":["Partner"],"parameters":[{"name":"id","in":"query","required":true,"schema":{"type":"string"}},{"$ref":"#/components/parameters/OffsetParam"},{"name":"limit","in":"query","schema":{"type":"integer","default":50,"maximum":100}}],"responses":{"200":{"description":"Discography"}}}},"/partner/concert-locations":{"get":{"summary":"Search concert locations","description":"Search Spotify for cities and venues. Returns `geoHash` and `geonameId` values that feed `/partner/concert-feed`.","tags":["Concerts"],"parameters":[{"name":"query","in":"query","required":true,"schema":{"type":"string"},"description":"City, venue, or place name."}],"responses":{"200":{"description":"Matching locations"}}}},"/partner/concert-feed":{"get":{"summary":"Concert feed by location","description":"List upcoming concerts in a geographic area (geoHash + geonameId, obtained from\n`/partner/concert-locations`). Returns paginated concert sections grouped by date.\nUse `details=true` to deep-search every concert in parallel and attach venue,\nlineup, and ticket providers.\n","tags":["Concerts"],"parameters":[{"name":"geoHash","in":"query","required":true,"schema":{"type":"string"},"description":"Spotify geohash (from `/partner/concert-locations`)."},{"name":"geonameId","in":"query","required":true,"schema":{"type":"string"},"description":"Geoname ID (from `/partner/concert-locations`)."},{"name":"from","in":"query","schema":{"type":"string","format":"date"},"description":"Start of date range (YYYY-MM-DD)."},{"name":"to","in":"query","schema":{"type":"string","format":"date"},"description":"End of date range (YYYY-MM-DD)."},{"name":"radiusInKm","in":"query","schema":{"type":"integer","default":100}},{"name":"conceptUris","in":"query","schema":{"type":"string"},"description":"Comma-separated Spotify concept URIs (e.g. `spotify:concept:rock,spotify:concept:pop`)."},{"name":"paginationKey","in":"query","schema":{"type":"string"},"description":"Pass back the `paginationKey` from a prior response."},{"$ref":"#/components/parameters/DetailsParam"},{"$ref":"#/components/parameters/DetailsLimitParam"},{"$ref":"#/components/parameters/ParsedParam"}],"responses":{"200":{"description":"Concert feed"},"400":{"description":"Invalid date format"}}}},"/partner/concert":{"get":{"summary":"Concert details","description":"Fetch full concert details by Spotify concert ID, URI, or open.spotify.com URL.\nReturns venue, lineup, ticket providers (DICE, Ticketmaster, etc.), accepted dates,\nfestival flag, related concerts, and partner sale links. Pass `parsed=true` for a\nflat, ready-to-consume shape.\n","tags":["Concerts"],"parameters":[{"name":"id","in":"query","required":true,"schema":{"type":"string"},"description":"Concert ID, `spotify:concert:URI`, or `open.spotify.com/concert/<id>` URL."},{"$ref":"#/components/parameters/ParsedParam"},{"name":"authenticated","in":"query","schema":{"type":"boolean","default":true},"description":"Set `false` to query as anonymous user (omits `me.profile` block)."}],"responses":{"200":{"description":"Concert payload"},"400":{"description":"Concert ID is required / invalid format"}}}},"/partner/artist-concerts":{"get":{"summary":"Artist upcoming concerts","description":"Fetch every upcoming concert/tour date for a Spotify artist.\nAccepts artist ID, `spotify:artist:URI`, or `open.spotify.com/artist/<id>` URL.\nWith `parsed=true` returns a flat